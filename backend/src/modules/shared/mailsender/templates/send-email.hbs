<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title></title>

  <style>
    .body {
      font-family: "Segoe UI";
    }

    img {
      width: 50px;
    }

    button {
      background-color: rgb(87, 91, 199);
      border: 1px solid rgb(87, 91, 199);
      color: white;
      padding: 10px;
      border-radius: 5px;
      font-weight: bold;
      margin-bottom: 15px;
      margin-top: 5px;
    }

    span {
      margin-top: 15px;
      color: grey;
    }

    a:hover {
      cursor: pointer;
    }

    button:hover {
      cursor: pointer;
    }

    p {
      color: grey;
    }
  </style>
</head>

<body class="body">
  {{{text}}}
</body>

</html>